@model ECommerce.Web.Models.CartViewModel
@{
    ViewData["Title"] = "My Cart";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <span class="eyebrow">Cart</span>
        <h1 class="h3 mb-0">Your shopping cart</h1>
    </div>
    @if (Model.Items.Any())
    {
        <form asp-action="Clear" method="post">
            @Html.AntiForgeryToken()
            <button class="btn btn-outline-danger btn-sm"
                    onclick="return confirm('Clear entire cart?')">
                Clear Cart
            </button>
        </form>
    }
</div>

@if (!Model.Items.Any())
{
    <div class="empty-state">
        <h2 class="h4 mb-2">Your cart is empty</h2>
        <p class="text-muted mb-3">Add products from the catalog to start checkout.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-accent">Browse Products</a>
    </div>
}
else
{
    <div class="checkout-progress mb-4">
        <div class="progress-step active">1. Cart</div>
        <div class="progress-step">2. Checkout</div>
        <div class="progress-step">3. Payment</div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Product</th>
                                <th>Unit Price</th>
                                <th>Quantity</th>
                                <th>Subtotal</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>@item.ProductName</td>
                                    <td>$@item.UnitPrice.ToString("0.00")</td>
                                    <td>@item.Quantity</td>
                                    <td>$@((item.UnitPrice * item.Quantity).ToString("0.00"))</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-success fw-bold">
                                <td colspan="3" class="text-end">Total</td>
                                <td>$@Model.Total.ToString("0.00")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm summary-card h-100">
                <div class="card-body p-4">
                    <span class="eyebrow">Summary</span>
                    <h2 class="h4 mb-3">Ready to checkout?</h2>
                    <p class="text-muted">Next, we’ll collect delivery details and move you to the payment step.</p>

                    <div class="summary-row">
                        <span>Items</span>
                        <strong>@Model.Items.Sum(i => i.Quantity)</strong>
                    </div>
                    <div class="summary-row">
                        <span>Total</span>
                        <strong>$@Model.Total.ToString("0.00")</strong>
                    </div>

                    <form asp-controller="Order" asp-action="Checkout" method="post" class="mt-4">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-accent btn-lg w-100">Continue to Checkout</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}
