@model List<ECommerce.Web.Models.ProductViewModel>
@{
    ViewData["Title"] = "Products";
}

<section class="page-hero mb-4 mb-lg-5">
    <div>
        <span class="eyebrow">Storefront</span>
        <h1 class="display-6 fw-semibold mb-2">Browse products with a clearer, more polished shopping experience.</h1>
        <p class="text-muted mb-0">Explore the catalog, inspect details, and add products to your cart with one click.</p>
    </div>
    @if (ViewBag.IsAdmin == true)
    {
        <a asp-action="Create" class="btn btn-accent btn-lg">Add Product</a>
    }
</section>

@if (!Model.Any())
{
    <div class="empty-state">
        <h2 class="h4 mb-2">No products available yet</h2>
        <p class="text-muted mb-0">Once products are added, they will appear here in the catalog.</p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            var imageUrl = string.IsNullOrWhiteSpace(product.ImageUrl)
                ? "https://placehold.co/640x480/e8ecef/5b6570?text=No+Image"
                : product.ImageUrl;

            <div class="col-sm-6 col-xl-4">
                <div class="card product-card h-100 border-0 shadow-sm">
                    <div class="product-image-wrap">
                        <img src="@imageUrl" class="product-image" alt="@product.Name" />
                    </div>
                    <div class="card-body d-flex flex-column p-4">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                            <h2 class="h5 card-title mb-0">@product.Name</h2>
                            <span class="badge text-bg-light">Stock: @product.Stock</span>
                        </div>
                        <p class="product-price mb-4">$@product.Price.ToString("0.00")</p>

                        <div class="mt-auto d-flex flex-wrap gap-2">
                            <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-dark">View Details</a>

                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline-flex">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="ProductId" value="@product.Id" />
                                <input type="hidden" name="Quantity" value="1" />
                                <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Products")" />
                                <button type="submit" class="btn btn-accent" @(product.Stock == 0 ? "disabled" : null)>Add to Cart</button>
                            </form>

                            @if (ViewBag.IsAdmin == true)
                            {
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-primary">Edit</a>

                                <form asp-action="Delete" method="post" class="d-inline-flex" onsubmit="return confirm('Delete this product?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button type="submit" class="btn btn-outline-danger">Delete</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
