@model ECommerce.Web.Models.EditProductViewModel
@{
    ViewData["Title"] = "Edit Product";
    var previewImage = string.IsNullOrWhiteSpace(Model.CurrentImageUrl)
        ? "https://placehold.co/640x480/e8ecef/5b6570?text=No+Image"
        : Model.CurrentImageUrl;
}

<div class="row justify-content-center py-lg-4">
    <div class="col-xl-9">
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4 p-lg-5">
                <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
                    <div>
                        <span class="eyebrow">Admin</span>
                        <h1 class="h3 mb-2">Edit product</h1>
                        <p class="text-muted mb-0">Update catalog details and replace the storefront image if needed.</p>
                    </div>
                    <a asp-action="Index" class="btn btn-outline-dark align-self-start">Back to Products</a>
                </div>

                <form asp-action="Edit" method="post" enctype="multipart/form-data" novalidate>
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <input asp-for="CurrentImageUrl" type="hidden" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                    <div class="row g-4 align-items-start">
                        <div class="col-lg-4">
                            <div class="detail-image-panel shadow-sm">
                                <img src="@previewImage" alt="@Model.Name" class="detail-image" />
                            </div>
                        </div>

                        <div class="col-lg-8">
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control form-control-lg" />
                                    <span asp-validation-for="Name" class="text-danger small"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Price" class="form-label"></label>
                                    <input asp-for="Price" class="form-control form-control-lg" type="number" step="0.01" min="0.01" />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>
                                <div class="col-md-3">
                                    <label asp-for="Stock" class="form-label"></label>
                                    <input asp-for="Stock" class="form-control form-control-lg" type="number" min="0" />
                                    <span asp-validation-for="Stock" class="text-danger small"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="ImageFile" class="form-label"></label>
                                    <input asp-for="ImageFile" class="form-control" accept="image/*" />
                                    <span asp-validation-for="ImageFile" class="text-danger small"></span>
                                    <div class="form-text">Upload a new image to replace the current storefront image.</div>
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="ImageUrl" class="form-label"></label>
                                    <input asp-for="ImageUrl" class="form-control" placeholder="https://example.com/product-image.jpg" />
                                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                    <div class="form-text">You can also switch to an external image URL.</div>
                                </div>
                            </div>

                            <div class="mt-4 d-flex justify-content-end">
                                <button type="submit" class="btn btn-accent btn-lg px-4">Save Changes</button>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
