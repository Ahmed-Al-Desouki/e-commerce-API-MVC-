@model List<ECommerce.Web.Models.OrderViewModel>
@{
    ViewData["Title"] = "My Orders";
}

<div class="mb-4">
    <span class="eyebrow">Orders</span>
    <h1 class="h3 mb-0">Your order history</h1>
</div>

@if (!Model.Any())
{
    <div class="empty-state">
        <h2 class="h4 mb-2">You have no orders yet</h2>
        <p class="text-muted mb-3">Complete checkout from your cart to see orders here.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-accent">Shop Now</a>
    </div>
}
else
{
    @foreach (var order in Model)
    {
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between">
                <span>Order #@order.OrderId</span>
                <span class="text-muted">@order.CreatedAt.ToString("dd MMM yyyy, HH:mm")</span>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Qty</th>
                            <th>Price</th>
                            <th>Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in order.Items)
                        {
                            <tr>
                                <td>@item.ProductName</td>
                                <td>@item.Quantity</td>
                                <td>$@item.Price.ToString("0.00")</td>
                                <td>$@((item.Price * item.Quantity).ToString("0.00"))</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="card-footer text-end fw-bold text-success">
                Total: $@order.TotalAmount.ToString("0.00")
            </div>
        </div>
    }
}
