@using ECommerce.API.Helpers
@{
    var isLoggedIn = SessionHelper.IsLoggedIn(Context.Session);
    var isAdmin = SessionHelper.IsAdmin(Context.Session);
    var username = SessionHelper.GetUsername(Context.Session);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | ECommerce</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="site-shell">
        <header>
            <nav class="navbar navbar-expand-lg app-navbar py-3">
                <div class="container">
                    <a class="navbar-brand fw-semibold" asp-controller="Products" asp-action="Index">ECommerce</a>
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav me-auto mb-3 mb-lg-0">
                            @if (isLoggedIn)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Products" asp-action="Index">Products</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Cart" asp-action="Index">Cart</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Order" asp-action="Index">Orders</a>
                                </li>
                                @if (isAdmin)
                                {
                                    <li class="nav-item">
                                        <a class="nav-link" asp-controller="Products" asp-action="Create">Add Product</a>
                                    </li>
                                }
                            }
                        </ul>
                        <div class="d-flex flex-column flex-lg-row align-items-lg-center gap-2">
                            @if (isLoggedIn)
                            {
                                <span class="user-chip">Signed in as @username</span>
                                <a class="btn btn-outline-light btn-sm px-3" asp-controller="Auth" asp-action="Logout">Logout</a>
                            }
                            else
                            {
                                <a class="btn btn-outline-light btn-sm px-3" asp-controller="Auth" asp-action="Login">Login</a>
                                <a class="btn btn-accent btn-sm px-3" asp-controller="Auth" asp-action="Register">Create account</a>
                            }
                        </div>
                    </div>
                </div>
            </nav>
        </header>

        <main class="page-content">
            <div class="container py-4 py-lg-5">
                @if (TempData["Success"] is string successMessage)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
                        @successMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Error"] is string errorMessage)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                        @errorMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </main>

        <footer class="site-footer mt-auto">
            <div class="container d-flex flex-column flex-md-row justify-content-between gap-2 py-4">
                <span>Modern shopping made simple.</span>
                <span>Login, browse, cart, checkout.</span>
            </div>
        </footer>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
