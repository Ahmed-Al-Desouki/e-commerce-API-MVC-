<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — ECommerce</title>
    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark px-4">
        <a class="navbar-brand" asp-controller="Products" asp-action="Index">🛒 ECommerce</a>
        <div class="ms-auto d-flex gap-2">
            <a class="btn btn-outline-light btn-sm"
               asp-controller="Products" asp-action="Index">Products</a>

            @if (Context.Session.GetString("JwtToken") != null)
            {
                <a class="btn btn-outline-light btn-sm"
                   asp-controller="Cart" asp-action="Index">Cart</a>
                <a class="btn btn-outline-light btn-sm"
                   asp-controller="Order" asp-action="Index">My Orders</a>
                <a class="btn btn-outline-danger btn-sm"
                   asp-controller="Auth" asp-action="Logout">Logout</a>
            }
            else
            {
                <a class="btn btn-outline-light btn-sm"
                   asp-controller="Auth" asp-action="Login">Login</a>
                <a class="btn btn-outline-success btn-sm"
                   asp-controller="Auth" asp-action="Register">Register</a>
            }
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>